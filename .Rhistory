library(devtools)
strsplit(x, split = split)[[1]]
splitstr1 = function(x, split) {
strsplit(x, split = split)[[1]]
}
use_r("strsplit1")
strsplit1 = function(x, split) {
strsplit(x, split = split)[[1]]
}
use_r("strsplit1")
load_all()
load_all()
x = "alfa,bravo,charlie,delta"
strsplit1(x, split =",")
exists("strsplit1", where = globalenv(), inherits = F)
exists("strsplit1", where = globalenv(), inherits = F)
